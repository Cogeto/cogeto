# Cogeto edge (decision 0002): TLS termination, SPA static files, reverse proxy.
# Dev instances use Caddy's internal CA (self-signed for localhost); managed
# instances swap this block for a real domain and ACME.

{
	local_certs
}

localhost {
	encode gzip

	# Zitadel paths on the shared origin (OIDC, login UI, console, APIs).
	# NOTE: Zitadel's asset API is /assets/v1/* — the bare /assets/* prefix belongs
	# to the SPA's Vite bundles and must NOT be proxied.
	@zitadel path /.well-known/* /oauth/* /oidc/* /ui/* /idps/* /saml/* /assets/v1/* /auth/v1/* /management/v1/* /admin/v1/* /system/v1/* /device* /zitadel*
	handle @zitadel {
		reverse_proxy zitadel:8080
	}

	# The Cogeto API (app process).
	handle /api/* {
		reverse_proxy app:3000
	}

	# The SPA: static files with history-API fallback.
	#
	# QS-19: strict Content-Security-Policy applied to the SPA responses ONLY
	# (never the proxied Zitadel login UI or the JSON API, which have their own
	# needs). script-src is 'self' with NO third-party sources and no
	# 'unsafe-inline' — an injected <script src=evil> or inline handler cannot
	# execute. style-src keeps 'unsafe-inline' (React sets element styles at
	# runtime); connect-src is 'self' because the API and Zitadel share this
	# origin. Tradeoff recorded (QS-19): the SPA holds the bearer token in
	# sessionStorage — accepted for v1, since a strict script-src is the real XSS
	# mitigation and the single-tenant origin (decision 0019) bounds exposure.
	handle {
		root * /srv
		header {
			Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
			X-Content-Type-Options "nosniff"
			Referrer-Policy "no-referrer"
			X-Frame-Options "DENY"
		}
		try_files {path} /index.html
		file_server
	}
}

# ── Infrastructure consoles moved out (QS-4) ──────────────────────────────────
# The s3.localhost / minio.localhost / qdrant.localhost vhosts USED to live here,
# on the public 80/443 listener — any reachable host could hit them by spoofing
# the Host header (unauthenticated Qdrant, MinIO console). They now live in
# Caddyfile.consoles, served by the `caddy-consoles` service under the
# `consoles` compose profile, bound to 127.0.0.1 only. The default deployment
# exposes EXACTLY this app vhost.
