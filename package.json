{
  "name": "cogeto",
  "version": "1.0.3",
  "private": true,
  "description": "Private, EU-hosted AI command center with verifiable memory",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "project/shared",
    "project/src",
    "project/web"
  ],
  "overridesRationale": "multer <=2.1.1 has two DoS advisories (GHSA-72gw-mp4g-v24j, GHSA-3p4h-7m6x-2hcm) reachable via the upload path (QS-12). It is a transitive dep of @nestjs/platform-express; the patched 2.2.0 line keeps the same API. Pinned here to avoid the breaking drizzle-orm/testcontainers bumps a bare `npm audit fix` would also pull in.",
  "overrides": {
    "multer": "^2.2.0"
  },
  "scripts": {
    "build": "npm run build -w @cogeto/shared && npm run build -w @cogeto/server && npm run build -w @cogeto/web",
    "verify:version": "node scripts/ci/verify-version.mjs",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "boundaries": "depcruise project/src project/shared project/web --config .dependency-cruiser.cjs",
    "test": "npm run test --workspaces --if-present",
    "gateway:smoke": "npm run build -w @cogeto/shared -w @cogeto/server && node project/src/dist/entrypoints/gateway-smoke.js",
    "reindex": "node project/src/dist/entrypoints/reindex.js",
    "eval": "npm run build -w @cogeto/shared -w @cogeto/server && node project/src/dist/entrypoints/eval.js",
    "eval:chat": "npm run build -w @cogeto/shared -w @cogeto/server && node project/src/dist/entrypoints/eval-chat.js",
    "vector:smoke": "node project/src/dist/entrypoints/vector-smoke.js",
    "seed:object": "npm run build -w @cogeto/shared -w @cogeto/server && node project/src/dist/entrypoints/seed-object.js",
    "seed:orphan": "npm run build -w @cogeto/shared -w @cogeto/server && node project/src/dist/entrypoints/seed-orphan.js",
    "sweep": "npm run build -w @cogeto/shared -w @cogeto/server && node project/src/dist/entrypoints/sweep.js",
    "dream": "npm run build -w @cogeto/shared -w @cogeto/server && node project/src/dist/entrypoints/dream.js",
    "reminders": "npm run build -w @cogeto/shared -w @cogeto/server && node project/src/dist/entrypoints/reminders.js",
    "eval:gate": "npm run build -w @cogeto/shared -w @cogeto/server && COGETO_EVAL_GATE=1 node project/src/dist/entrypoints/eval.js",
    "demo:seed": "npm run build -w @cogeto/shared -w @cogeto/server && node project/src/dist/entrypoints/demo-seed.js",
    "demo:reset": "npm run build -w @cogeto/shared -w @cogeto/server && node project/src/dist/entrypoints/demo-reset.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "dependency-cruiser": "^16.10.0",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0",
    "vitest": "^3.1.4"
  }
}
