# Cogeto — environment for docker compose (copy to .env to override).
# Every variable has a safe DEV default baked into docker-compose.yml, so a
# fresh clone works with zero configuration. NEVER use these defaults on a
# reachable host; provisioning injects real secrets per instance (Technical
# Architecture §10). .env is gitignored — secrets are never committed.

# ── External identity of the instance ─────────────────────────────────────────
# Domain the browser uses; also Zitadel's external domain (Host-based routing).
COGETO_EXTERNAL_DOMAIN=localhost

# ── PostgreSQL (source of truth) ──────────────────────────────────────────────
# Superuser password; also used by Zitadel's init to create its own database.
POSTGRES_PASSWORD=cogeto-dev-password

# ── MinIO (file bytes, S3 API — SSE-S3 encryption at rest, decision 0008) ────
MINIO_ROOT_USER=cogeto
MINIO_ROOT_PASSWORD=cogeto-dev-password
# Console origin behind the Caddy edge (decision 0017) — default suits the
# *.localhost setup. Do NOT set MINIO_SERVER_URL (breaks console login; see
# decision 0017). Presigned downloads use the Host header, not this.
#MINIO_BROWSER_REDIRECT_URL=https://minio.localhost
# Server-side encryption master key (single-node KMS). Format is
# <key-name>:<base64 of 32 random bytes>. Generate a real one per instance:
#   echo "cogeto-instance-key:$(openssl rand -base64 32)"
# The default baked into docker-compose.yml is DEV-ONLY — never rely on it on a
# reachable host. Losing this key makes stored objects unreadable; back it up
# with the instance secrets. Key rotation requires KES and is a Later item.
MINIO_KMS_SECRET_KEY=

# ── Zitadel (identity, SSO) ──────────────────────────────────────────────────
# Symmetric masterkey for Zitadel's encryption keys — MUST be exactly 32 chars.
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters
# Password for the dedicated zitadel database user (created on first init).
ZITADEL_DB_PASSWORD=zitadel-dev-password
# First organization and human admin created on first init (§A.2, zero clicks).
ZITADEL_ORG_NAME=Cogeto
ZITADEL_ADMIN_USERNAME=admin@cogeto.localhost
# Must satisfy Zitadel's default policy: upper + lower + digit + symbol.
ZITADEL_ADMIN_PASSWORD=DevPassword1!

# ── Model providers (§A.10; decision 0040 — bring your own key) ──────────────
# All keys are used ONLY inside the model-gateway seam and are never entered
# through the UI, stored in the database, logged, or exposed by any endpoint.
# Optional: without any key the stack runs fine (login, dashboard, queue);
# model calls fail with a typed error until a provider is configured.
# Get a Mistral key at console.mistral.ai. Never commit keys; .env is gitignored.
COGETO_MISTRAL_API_KEY=

# Per-task model tiers (decision 0007 ruling 3). Task sites request a TIER, not
# a model; configuration maps tiers to concrete provider models.
#  - PIPELINE:   extraction + verification (high volume, cheaper model).
#  - ANSWER:     chat synthesis + the eval grader (lower volume, stronger model).
#  - EMBEDDINGS: recorded per memory; changing provider OR model requires
#                `npm run reindex` before the instance will serve again
#                (mixed embedding spaces are refused at boot — decision 0040).
# Legacy Mistral tier vars — still honored when the tier's provider is mistral.
COGETO_MISTRAL_MODEL_PIPELINE=mistral-small-latest
COGETO_MISTRAL_MODEL_ANSWER=mistral-medium-latest
COGETO_MISTRAL_EMBED_MODEL=mistral-embed

# Bring-your-own-key providers (decision 0040). A preset picks all three tiers
# at once; per-tier vars override it. Validated AT BOOT: an unknown provider, a
# missing key, a missing model, or embeddings on a provider without an
# embeddings API (Anthropic) refuse to start with a clear message.
# Presets: mistral-default (the default) | openai-default | anthropic-answer
#          | ollama-local (all three tiers on a local Ollama runtime — 0041).
#COGETO_PROVIDER_PRESET=mistral-default
# Per-tier provider (mistral|openai|anthropic|ollama) + model. A non-mistral
# provider needs an explicit model unless the preset already named one.
#COGETO_PROVIDER_PIPELINE=
#COGETO_MODEL_PIPELINE=
#COGETO_PROVIDER_ANSWER=
#COGETO_MODEL_ANSWER=
#COGETO_PROVIDER_EMBEDDINGS=
#COGETO_MODEL_EMBEDDINGS=
# OpenAI-compatible endpoint: key + base URL (default https://api.openai.com/v1;
# point it at any server speaking the OpenAI API shape).
#COGETO_OPENAI_API_KEY=
#COGETO_OPENAI_BASE_URL=
# Anthropic: key + base URL (default https://api.anthropic.com). No embeddings
# API — the embeddings tier must stay on mistral or an OpenAI-compatible one.
#COGETO_ANTHROPIC_API_KEY=
#COGETO_ANTHROPIC_BASE_URL=
# Local Ollama runtime (decision 0041 — Post-v1 Priority 4). The base URL is
# the runtime ROOT (no /v1) and has no default: localhost, LAN, and WireGuard
# addresses are all valid — the containers must be able to reach it (see
# docs/notes/local-models.md for the networking note). No API key needed; the
# optional key is only for a runtime behind an authenticating reverse proxy.
# Per-tier timeouts default high for local inference (300000/300000/120000 ms).
# Mixed-posture examples (per-tier overrides beat the preset):
#   hosted generation + local embeddings:
#     COGETO_PROVIDER_EMBEDDINGS=ollama  COGETO_MODEL_EMBEDDINGS=bge-m3
#   local pipeline + hosted answer:
#     COGETO_PROVIDER_PIPELINE=ollama    COGETO_MODEL_PIPELINE=gemma3:12b
# Switching the embeddings tier requires `npm run reindex` (decision 0040/0041).
#COGETO_OLLAMA_BASE_URL=
#COGETO_OLLAMA_API_KEY=
#COGETO_OLLAMA_TIMEOUT_PIPELINE_MS=
#COGETO_OLLAMA_TIMEOUT_ANSWER_MS=
#COGETO_OLLAMA_TIMEOUT_EMBEDDINGS_MS=
# Eval-harness-only (never read by the instance): re-bind the eval grader away
# from the answer tier — see docs/notes/model-providers.md before using.
#COGETO_PROVIDER_GRADER=
#COGETO_MODEL_GRADER=

# ── Application ──────────────────────────────────────────────────────────────
# pino level for app and worker: trace|debug|info|warn|error|fatal
COGETO_LOG_LEVEL=info

# ── Abuse / DoS limits (FIX-2: QS-2, QS-6, QS-14) ────────────────────────────
# All optional — sane defaults live in the code, and demoMode auto-tightens the
# aggressive set (the demo override vars below apply only to the public
# sandbox). Defaults are generous for a real user and only bite runaway loops /
# anonymous demo abuse. A rate-limit bucket of 0 is unlimited.
#
# Per-principal request rate (fixed window). Window is shared by all buckets.
#COGETO_RATELIMIT_WINDOW_SECONDS=60
#COGETO_RATELIMIT_CHAT=30           # POST /api/chat (model-cost vector)
#COGETO_RATELIMIT_CAPTURE=60        # POST /api/notes
#COGETO_RATELIMIT_REMEMBER=30       # POST /api/chat/messages/:id/remember
#COGETO_RATELIMIT_UPLOAD=20         # POST /api/files
#COGETO_DEMO_RATELIMIT_CHAT=12
#COGETO_DEMO_RATELIMIT_CAPTURE=60   # must clear the 31-note demo seed burst
#COGETO_DEMO_RATELIMIT_REMEMBER=15
#COGETO_DEMO_RATELIMIT_UPLOAD=10
#
# Per-user daily model budget, enforced in the gateway on user-attributed calls
# (chat path). Estimated tokens ≈ chars/4. On exhaustion the user gets a 429 /
# "limit reached" until UTC midnight; the worker pipeline is unmetered here.
#COGETO_MODEL_DAILY_CALLS=2000
#COGETO_MODEL_DAILY_TOKENS=4000000
#COGETO_DEMO_MODEL_DAILY_CALLS=400
#COGETO_DEMO_MODEL_DAILY_TOKENS=800000
#
# Per-user daily capture/upload cap (bounds the pipeline work a user can drive).
#COGETO_DAILY_CAPTURE_MAX=1000
#COGETO_DAILY_UPLOAD_MAX=300
#COGETO_DEMO_DAILY_CAPTURE_MAX=500
#COGETO_DEMO_DAILY_UPLOAD_MAX=100
#
# Chat SSE bounds (QS-14): concurrent streams per principal, idle + max duration.
#COGETO_SSE_MAX_CONCURRENT=3
#COGETO_DEMO_SSE_MAX_CONCURRENT=2
#COGETO_SSE_IDLE_TIMEOUT_SECONDS=60
#COGETO_SSE_MAX_DURATION_SECONDS=180
#
# Document/extraction parse caps (QS-6): decompressed-text length, chunk count,
# per-parse wall-clock timeout, and max facts admitted per source.
#COGETO_PARSE_MAX_TEXT_CHARS=1000000
#COGETO_PARSE_MAX_CHUNKS=200
#COGETO_PARSE_TIMEOUT_SECONDS=30
#COGETO_EXTRACT_MAX_FACTS=100

# ── Qdrant (vector index) ────────────────────────────────────────────────────
# API key (QS-4). The default compose stack keeps Qdrant on the internal network
# with no key; SET this (and it is passed to the qdrant service as
# QDRANT__SERVICE__API_KEY) before exposing the console vhosts / a reachable host.
#COGETO_QDRANT_API_KEY=

# ── File upload (O1) ─────────────────────────────────────────────────────────
# Max bytes per upload (default 25 MiB); PDFs and DOCX only.
#COGETO_UPLOAD_MAX_BYTES=26214400
# Presigned download-URL lifetime in seconds (default 300; §A.9 short-lived).
#COGETO_DOWNLOAD_URL_TTL_SECONDS=300

# ── Inbound email (decisions 0028/0031) ──────────────────────────────────────
# Sender-routed capture: mail from a registered user's address is captured for
# that user; mail from other senders is routed by each user's allowlist. The
# bootstrap admin (operator) account never captures — compose derives this from
# ZITADEL_ADMIN_USERNAME; override only if the admin login differs.
#COGETO_ADMIN_USER_EMAIL=admin@cogeto.localhost
# The instance's unique inbound address; the operator script derives this as
# capture@in.<domain> and the UI shows it with forwarding-setup guidance.
#COGETO_MAIL_INBOUND_ADDRESS=capture@in.localhost
# Shared secret the Haraka container presents on POST /api/email/intake. The
# deploy stack REQUIRES this (no default); the operator script generates one.
# Refused as a known dev value on a non-localhost deployment (secret-preflight).
#COGETO_MAIL_INTAKE_TOKEN=
# Max bytes for a whole inbound message / a single attachment (defaults 25 MiB).
#COGETO_MAIL_MAX_BYTES=26214400
#COGETO_MAIL_ATTACHMENTS_MAX_BYTES=26214400
# Host port the Haraka SMTP listener publishes (default 25) and the in-network
# SMTP address of the mail container.
#COGETO_MAIL_HOST_PORT=25
#COGETO_MAIL_SMTP_ADDRESS=mail:2525
# Sender authentication (SEC-1). When 1 (default), a message is captured for the
# registered user it claims to be from ONLY if the SMTP sender passed SPF, so a
# spoofed From cannot inject that user's memory; a hard SPF fail is refused. Set
# 0 only on a closed test instance without inbound SPF.
#COGETO_MAIL_REQUIRE_SPF=1
# Per-sender accepted-message cap within the intake window (SEC-2) — bounds the
# ingestion/model spend one internet sender can drive. 0 disables the cap.
#COGETO_MAIL_INTAKE_MAX_PER_SENDER=60
#COGETO_MAIL_INTAKE_RATE_WINDOW_SECONDS=3600
# Inbound STARTTLS (GAP-2): paths (inside the mail container's mail-tls volume)
# to the instance cert/key. Absent/unreadable → STARTTLS is not advertised.
#COGETO_MAIL_TLS_CERT=/app/tls/cert.pem
#COGETO_MAIL_TLS_KEY=/app/tls/key.pem

# ── Instance behaviour (FIX-3) ───────────────────────────────────────────────
# Instance timezone (QS-32) — relative dates ("today"/"tomorrow"/"last Monday")
# resolve against local midnight in THIS IANA zone, not UTC, fixing the
# near-midnight off-by-one for the EU audience. Default Europe/Zagreb.
#COGETO_TIMEZONE=Europe/Zagreb
# Zitadel role that gates the operational jobs endpoints (QS-10). Default 'admin'.
#COGETO_ADMIN_ROLE=admin
# Postgres connection-pool ceiling PER PROCESS (QS-38). Sized against worker
# concurrency (2); the pipeline holds its idempotency tx open across model calls,
# so each in-flight job pins a connection. Default 10 — raise with concurrency.
#COGETO_PG_POOL_MAX=10
# Browser-reachable object-storage origin used ONLY to sign presigned download
# URLs. Compose defaults it to https://s3.localhost (served by Caddy → minio,
# decision 0017), which makes O1 downloads work once the *.localhost DNS entry
# is added. Override for a real domain (a browser-reachable S3 origin).
#COGETO_S3_PUBLIC_URL=https://s3.localhost

# Paths the processes read at boot (audit 2.10). Compose sets sensible values;
# override only for unusual layouts (e.g. running entrypoints outside Docker).
#  - COGETO_MIGRATIONS_DIR: where the migrate entrypoint finds the reviewable
#    SQL files (default: project/src/migrations relative to the built code).
#  - COGETO_PROMPTS_DIR: where the model-gateway prompt loader finds the
#    versioned prompt artifacts (default: project/prompts).
#  - COGETO_INSTANCE_KEY_DIR: where the instance ed25519 signing keypair lives
#    (deletion receipts, §B.1). Compose mounts the instance-keys volume here;
#    the migrate init job generates the keypair on first boot (decision 0008).
#COGETO_MIGRATIONS_DIR=
#COGETO_PROMPTS_DIR=
#COGETO_INSTANCE_KEY_DIR=

# ── Ana sandbox (decision 0022; profile demo) ────────────────────────────────
# NEVER set demo mode on a customer instance — the demo publishes a working
# access token for anyone, safe ONLY because the instance holds no real data.
#  - COGETO_DEMO_MODE: force sandbox mode + enable the worker's scheduled reset.
#    (The app auto-detects sandbox mode from the seeded session file even without
#    this, so `docker compose --profile demo up` is enough to populate a sandbox.)
#  - COGETO_PRODUCTION / COGETO_ENV=production: hard-refuse the demo seed/reset.
#  - COGETO_DEMO_RESET_CRON: scheduled-reset cadence (default every 6 hours).
#  - COGETO_DEMO_SESSION_FILE: where the demo Principal's session is published
#    (default /demo-config/session.json; served on /api/config in demo mode).
#COGETO_DEMO_MODE=
#COGETO_PRODUCTION=
#COGETO_ENV=
#COGETO_DEMO_RESET_CRON=0 */6 * * *
#COGETO_DEMO_SESSION_FILE=/demo-config/session.json

# ── Redaction mode (§B.8, profile redaction; decisions 0002/0023) ────────────
# Local CPU NER pseudonymizes sensitive entities before any external model call
# and re-identifies the response. Enable WITH the profile up:
#   REDACTION_ENABLED=1 docker compose --profile redaction up --build
#  - REDACTION_ENABLED: turn the gateway's redaction stage on (1/true).
#  - REDACTION_URL: sidecar base URL (compose defaults to the service name).
#  - REDACTION_SPACY_MODEL: NER model (en_core_web_lg default; en_core_web_md for
#    ~half the RAM at lower accuracy). If enabled and the sidecar is unreachable,
#    model calls FAIL CLOSED (never sent in plaintext).
#  - REDACTION_REQUIRED: fail-closed assertion (QS-21). Set to 1 to REFUSE boot
#    unless REDACTION_ENABLED is on — bringing the profile up while forgetting the
#    enable flag then fails loudly instead of silently sending plaintext.
#REDACTION_ENABLED=
#REDACTION_URL=http://redaction:8080
#REDACTION_SPACY_MODEL=en_core_web_lg
#REDACTION_REQUIRED=

# ── Web research (Priority 5 Part A, profile research; decisions 0042/0043) ──
# Discovery is the self-hosted SearXNG container; the narrow fetcher pulls the
# selected pages server-side. Bring discovery up with:
#   docker compose --profile research up
#  - COGETO_SEARXNG_URL: SearXNG base URL on the internal network (compose
#    defaults to the service name). Unset/unreachable → research search answers
#    a typed "search unavailable"; nothing else is affected.
#  - SEARXNG_SECRET: SearXNG server secret (dev default in compose;
#    provisioning generates a real one per instance).
#  - COGETO_RESEARCH_RESULT_CAP: max ranked results one discovery query returns.
#  - COGETO_RESEARCH_SEARCH_TIMEOUT_SECONDS / COGETO_RESEARCH_FETCH_TIMEOUT_SECONDS:
#    hard timeouts around one search / one page fetch.
#  - COGETO_RESEARCH_FETCH_MAX_BYTES: response-size cap per fetched page.
#  - COGETO_RESEARCH_PAGES_PER_RUN: max pages one capture request may fetch.
#  - COGETO_RESEARCH_RETAIN_HTML: 1 = additionally retain the sanitised raw
#    HTML as a scoped, encrypted MinIO object (default off — the retained clean
#    text + URL are the source of record, decision 0043).
#  - COGETO_DAILY_RESEARCH_SEARCHES / COGETO_DAILY_RESEARCH_PAGES: per-user
#    daily budgets (FIX-2); the demo-namespace variants below tighten them on
#    the sandbox.
#COGETO_SEARXNG_URL=http://searxng:8080
#SEARXNG_SECRET=
#COGETO_RESEARCH_RESULT_CAP=8
#COGETO_RESEARCH_SEARCH_TIMEOUT_SECONDS=10
#COGETO_RESEARCH_FETCH_TIMEOUT_SECONDS=15
#COGETO_RESEARCH_FETCH_MAX_BYTES=5242880
#COGETO_RESEARCH_PAGES_PER_RUN=5
#COGETO_RESEARCH_RETAIN_HTML=
#COGETO_DAILY_RESEARCH_SEARCHES=40
#COGETO_DAILY_RESEARCH_PAGES=100
#COGETO_DEMO_DAILY_RESEARCH_SEARCHES=10
#COGETO_DEMO_DAILY_RESEARCH_PAGES=20
