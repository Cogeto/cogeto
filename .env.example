# Cogeto — environment for docker compose (copy to .env to override).
# Every variable has a safe DEV default baked into docker-compose.yml, so a
# fresh clone works with zero configuration. NEVER use these defaults on a
# reachable host; provisioning injects real secrets per instance (Technical
# Architecture §10). .env is gitignored — secrets are never committed.

# ── External identity of the instance ─────────────────────────────────────────
# Domain the browser uses; also Zitadel's external domain (Host-based routing).
COGETO_EXTERNAL_DOMAIN=localhost

# ── PostgreSQL (source of truth) ──────────────────────────────────────────────
# Superuser password; also used by Zitadel's init to create its own database.
POSTGRES_PASSWORD=cogeto-dev-password

# ── MinIO (file bytes, S3 API — SSE-S3 encryption at rest, decision 0008) ────
MINIO_ROOT_USER=cogeto
MINIO_ROOT_PASSWORD=cogeto-dev-password
# Console origin behind the Caddy edge (decision 0017) — default suits the
# *.localhost setup. Do NOT set MINIO_SERVER_URL (breaks console login; see
# decision 0017). Presigned downloads use the Host header, not this.
#MINIO_BROWSER_REDIRECT_URL=https://minio.localhost
# Server-side encryption master key (single-node KMS). Format is
# <key-name>:<base64 of 32 random bytes>. Generate a real one per instance:
#   echo "cogeto-instance-key:$(openssl rand -base64 32)"
# The default baked into docker-compose.yml is DEV-ONLY — never rely on it on a
# reachable host. Losing this key makes stored objects unreadable; back it up
# with the instance secrets. Key rotation requires KES and is a Later item.
MINIO_KMS_SECRET_KEY=

# ── Zitadel (identity, SSO) ──────────────────────────────────────────────────
# Symmetric masterkey for Zitadel's encryption keys — MUST be exactly 32 chars.
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters
# Password for the dedicated zitadel database user (created on first init).
ZITADEL_DB_PASSWORD=zitadel-dev-password
# First organization and human admin created on first init (§A.2, zero clicks).
ZITADEL_ORG_NAME=Cogeto
ZITADEL_ADMIN_USERNAME=admin@cogeto.localhost
# Must satisfy Zitadel's default policy: upper + lower + digit + symbol.
ZITADEL_ADMIN_PASSWORD=DevPassword1!

# ── Model (Mistral API, EU — §A.10) ──────────────────────────────────────────
# Used ONLY inside the model-gateway seam. Optional: without it the stack runs
# fine (login, dashboard, queue); model calls fail with a typed error until set.
# Get a key at console.mistral.ai. Never commit it; .env is gitignored.
COGETO_MISTRAL_API_KEY=

# Per-task model tiers (decision 0007 ruling 3). Task sites request a TIER, not
# a model; these map tiers to concrete Mistral models.
#  - PIPELINE: extraction + verification (high volume, cheaper model).
#  - ANSWER:   chat synthesis + the eval grader (lower volume, stronger model).
# Cost note: only the low-volume answer path uses the pricier model; the
# high-volume ingestion path (and embeddings) stay on the cheap tier, so the
# split raises quality where the user reads output without moving the cost floor.
COGETO_MISTRAL_MODEL_PIPELINE=mistral-small-latest
COGETO_MISTRAL_MODEL_ANSWER=mistral-medium-latest
# Embedding model — recorded per memory; changing it triggers a reindex.
COGETO_MISTRAL_EMBED_MODEL=mistral-embed

# ── Application ──────────────────────────────────────────────────────────────
# pino level for app and worker: trace|debug|info|warn|error|fatal
COGETO_LOG_LEVEL=info

# ── File upload (O1) ─────────────────────────────────────────────────────────
# Max bytes per upload (default 25 MiB); PDFs and DOCX only.
#COGETO_UPLOAD_MAX_BYTES=26214400
# Presigned download-URL lifetime in seconds (default 300; §A.9 short-lived).
#COGETO_DOWNLOAD_URL_TTL_SECONDS=300
# Browser-reachable object-storage origin used ONLY to sign presigned download
# URLs. Compose defaults it to https://s3.localhost (served by Caddy → minio,
# decision 0017), which makes O1 downloads work once the *.localhost DNS entry
# is added. Override for a real domain (a browser-reachable S3 origin).
#COGETO_S3_PUBLIC_URL=https://s3.localhost

# Paths the processes read at boot (audit 2.10). Compose sets sensible values;
# override only for unusual layouts (e.g. running entrypoints outside Docker).
#  - COGETO_MIGRATIONS_DIR: where the migrate entrypoint finds the reviewable
#    SQL files (default: project/src/migrations relative to the built code).
#  - COGETO_PROMPTS_DIR: where the model-gateway prompt loader finds the
#    versioned prompt artifacts (default: project/prompts).
#  - COGETO_INSTANCE_KEY_DIR: where the instance ed25519 signing keypair lives
#    (deletion receipts, §B.1). Compose mounts the instance-keys volume here;
#    the migrate init job generates the keypair on first boot (decision 0008).
#COGETO_MIGRATIONS_DIR=
#COGETO_PROMPTS_DIR=
#COGETO_INSTANCE_KEY_DIR=

# ── Ana sandbox (decision 0022; profile demo) ────────────────────────────────
# NEVER set demo mode on a customer instance — the demo publishes a working
# access token for anyone, safe ONLY because the instance holds no real data.
#  - COGETO_DEMO_MODE: force sandbox mode + enable the worker's scheduled reset.
#    (The app auto-detects sandbox mode from the seeded session file even without
#    this, so `docker compose --profile demo up` is enough to populate a sandbox.)
#  - COGETO_PRODUCTION / COGETO_ENV=production: hard-refuse the demo seed/reset.
#  - COGETO_DEMO_RESET_CRON: scheduled-reset cadence (default every 6 hours).
#  - COGETO_DEMO_SESSION_FILE: where the demo Principal's session is published
#    (default /demo-config/session.json; served on /api/config in demo mode).
#COGETO_DEMO_MODE=
#COGETO_PRODUCTION=
#COGETO_ENV=
#COGETO_DEMO_RESET_CRON=0 */6 * * *
#COGETO_DEMO_SESSION_FILE=/demo-config/session.json
